# Auth service URL (defaults to https://auth.criticalbit.gg in production)
VITE_AUTH_URL=http://localhost:5174

# PostHog analytics — shared "criticalbit" project (US Cloud)
# Leave unset in dev to log analytics to console instead of sending to PostHog.
# In production, set these in the Netlify dashboard.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
